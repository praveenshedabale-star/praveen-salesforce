//Trigger
Trigger ContactTrigger on Contact(After insert, After Delete){
	if(Trigger.isAfter){
		if(Trigger.isInsert){
			ContactHandler.UpdateContactsCountOnAccount(Trigger.new,null);
		}
		if(Trigger.isDelete){
			ContactHandler.UpdateContactsCountOnAccount(null,Trigger.Old);
		}
	}
}

//Handler
public class ContactHandler(){
	public static void UpdateContactsCountOnAccount(List<Contact> conNewList, List<Contact> conOldList){
		Set<Id> accIds = new Set<Id>();
		if(Trigger.isInsert){
			for(Contact con : conNewList){
				if(con.AccountId != null){
					accIds.add(con.AccountId);
				}
			}
		}
		if(Trigger.isDelete){
			for(Contact con : conOldList){
				if(con.AccountId != null){
					accIds.add(con.AccountId);
				}
			}
		}
		
		if(accIds.isEmpty()) return;
		Map<Id,Integer> accConCountMap = new Map<Id,Integer>();
		for(AggregateResult arr : [select accountId accId, Count(id) contactCount from Contact where AccountId in : accIds group by AccountId]){
			accConCountMap.put((Id) arr.get('accId'), (Integer) arr.get('contactCount'));
		}
		
		if(!accConCountMap.isEmpty){
			List<Account> accUpdate= new List<Account>();
			for(Id id : accIds){
				Account acc =  new Account();
				acc.Id = id;
				acc.total_contact__c = accConCountMap.get(Id);
				accUpdate.add(acc);
			}
			if(!accUpdate.isEmpty()){
				Update accUpdate;
			}
		}
	}
}



