Public Class ContactTriggerHandler {
	Public Static Void UpdateAccountField(List<Contact> conNewList,List<Contact> conOldList){
	Set<Id> accIds = new Set<Id>();
		if(Trigger.isInsert){
			for(Contact con : conNewList){
				if(con.AccountId != null){
					accIds.add(con.AccountId);
				}
			}
		}
		if(Trigger.isDelete){
			for(Contact con : conOldList){
				if(con.AccountId != null){
					accIds.add(con.AccountId);
				}
			}
		}
		
		if(accIds.isEmpty) return;
		Map<Id,Integer> accConCountMap = new Map<Id,Integer>();
		for(AggregateResult arr : [select AccountId accId, Count(Id) conIdCount from Contact where id In : accIds Group by AccountId]){
			accConCountMap.put((Id) arr.get('accId'),(Integer) arr.get('conIdCount'));
		}
		
		if(!accConCountMap.isEmpty()){
		List<Account> accUpdateList = new List<Account>();
			for(Id Ids : accIds){
				if(accConCountMap.containKey(con.AccountId)){
					Account acc = new Account();
					acc.id = Ids;
					acc.total_contact__c = accConCountMap.get(Ids);
					accList.add(acc);
				}
			}
			if(!accUpdateList.isEmpty()){
				Update accUpdateList;
			}
		}
	}
}

