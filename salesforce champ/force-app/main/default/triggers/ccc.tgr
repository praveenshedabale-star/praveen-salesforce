Public class contactTriggerHandler{

	public static void contactUpdate(List<Contact> conList,Map<id,Contact> conOldMap){
			Map<Id,Contact> conAccIdMap = new Map<Id,Contact>();
			for(Contact con : conList){
				if(con.AccountId != null && con.Rating__c != null && Trigger.isInsert || (Trigger.isUpdate && conOldMap.get(con.id).Rating__c != con.Rating__c)){
						conAccIdMap.put(con.AccountId, con);
				}
			}
			
			if(conAccIdMap.isEmpty()) return;
			List<Account> accUpdateList = new List<Account>();
			for(Account acc : [select id,Accountid, Rating__c from Account where id in : conAccMap.keySet()]){
			 	acc.Rating__c = conAccIdMap.get(acc.id).Rating__c;
			 	accUpdateList.add(acc);
			}
			
			if(!accUpdateList.isEmpty()){
				Update accUpdateList;
			}
	}

}





