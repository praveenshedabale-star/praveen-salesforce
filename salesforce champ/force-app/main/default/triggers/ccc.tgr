//HANDLER

public class ContactTriggerHandler{

	public static void accountUpdate(List<Contact> conNewList,List<Contact> conOldList){
		Set<Id> accIds = new Set<Id>();
		if(Trigger.isInsert || Trigger.isUndelete){
			for(Contact con : conNewList){
			 if(con.AccountId != null);
				accIds.add(con.AccountId);
			}
		}
		
		if(Trigger.isDelete){
			for(Contact con : conOldList){
					if(con.AccountId != null){
						accids.add(con.AccountId);
					}
			}
		}
		
		if(accIds.isEmpty()) return;
		Map<Id,Integer> conMap = new Map<Id,Integer>();
		for(AggregateResult arr : [select count(id) countCon, Accounid accid from Contact where id in : accIds group by Accountid]){
			conMap.put((Id) arr.get('accid'),(Number) arr.get('countCon'));
		}
		List<Account> accUpdateList = new List<Account>();
		for(id id : accIds){
				account acc = new account();
				acc.id = id;
				acc.Total_Contact__c = if(!conMap.isEmpty) conMap.get(id) : 0;
				accUpdateList.add(acc);
		}
		
		if(!accUpdateList.isEmpty){
			Update accUpdateList;
		}
	}

}
