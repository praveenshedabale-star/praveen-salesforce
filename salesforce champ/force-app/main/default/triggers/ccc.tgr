//js
import {LightningElement} from 'lwc';
import {ShowToastEvent} from 'lightning/PlatformShowtoastEvent';
import saveAccountRecord from '@salesforce/apex/AccountController.createRecord';
export default class SaveRecordExample extends LightningElement{
    
        accountName;
        
        handleChange(event){
            this.accountName = event.target.value;
        }
    
    saveRecord(){
        saveAccountRecord({accName : this.accountName})
        .then(result=>{
            const evt = new ShowToastEvent({
                title : 'success',
                message : 'Record created successfully',
                Variant : 'success'
            });
            this.dispatchEvent(evt);
        })
        .then(error=>{
            const evt = new ShowToastEvent({
                title : 'success',
                message : error.body.message,
                Variant : 'error'
            });
            
            this.dispatchEvent(evt);
        })
    }
}

